rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isVolunteer() {
      return request.auth != null && request.auth.token.email == "volunteer@gmail.com";
    }

    match /matches/{matchId}/{fileName} {
      allow read: if true;
      allow write: if isVolunteer();
    }
  }
}
