rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated and is a volunteer
    function isVolunteer() {
      return request.auth != null && request.auth.token.email == "volunteer@gmail.com";
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /matches/{matchId} {
      // Anyone can read matches for real-time dashboard updates
      allow read: if true;
      // Only volunteers can create/update match details
      allow write: if isVolunteer();
    }
    
    match /activityLogs/{logId} {
      // Anyone can read activity logs
      allow read: if true;
      // Only volunteers can write activity logs
      allow write: if isVolunteer();
    }
    
    match /liveFeeds/{feedId} {
      allow read: if true;
      allow write: if isVolunteer();
    }
    
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isVolunteer();
    }
  }
}
