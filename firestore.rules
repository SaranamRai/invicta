rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated and is a volunteer or admin
    function isVolunteer() {
      return request.auth != null && request.auth.token.email == "volunteer@gmail.com";
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "admin@gmail.com";
    }

    function isOperator() {
      return isVolunteer() || isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /matches/{matchId} {
      // Anyone can read matches for real-time dashboard updates
      allow read: if true;
      // Admin creates schedule; volunteers update live match details
      allow write: if isOperator();
    }

    match /teams/{teamId} {
      allow read: if true;
      // Public registration creates teams; admin manages them after creation.
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /activityLogs/{logId} {
      // Anyone can read activity logs
      allow read: if true;
      // Only volunteers can write activity logs
      allow write: if isOperator();
    }
    
    match /liveFeeds/{feedId} {
      allow read: if true;
      allow write: if isOperator();
    }
    
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isOperator();
    }
  }
}
